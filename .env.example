# Configuración del servidor TaskDelayWeb

# Puerto en el que corre el servidor (default: 3000)
PORT=3000

# URL de conexión a MongoDB Atlas
# ⚠️ NO INCLUYAS CREDENCIALES AQUÍ - Usa management de secretos:
#    Local: establece MONGODB_URI en tu .env (git-ignored)
#    Heroku: Settings > Config Vars > MONGODB_URI
MONGODB_URI=

# Ambiente (development, production)
NODE_ENV=development
